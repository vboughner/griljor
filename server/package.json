{
  "name": "griljor-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon --exec ts-node src/main.ts",
    "lobby": "ts-node src/lobby.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "lint": "eslint src",
    "format": "prettier --write src",
